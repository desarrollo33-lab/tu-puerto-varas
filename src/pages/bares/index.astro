<BaseLayout title="Bares & Noche en puerto varas | Los mejores" description="Descubre los mejores bares & noche en puerto varas. Reseñas, precios y tips locales. Guía actualizada 2026.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">🍻</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Bares & Noche en puerto varas</h1>
      <p class="text-white/80 text-lg max-w-2xl">La guía más completa. Reseñas, precios y tips de locales.</p>
    </div>
  </section>
