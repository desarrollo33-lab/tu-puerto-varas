---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catListing } from '../../data/content';
const items = catListing['bares'] || [];
---
<BaseLayout title="Bares & Noche en puerto varas | Los mejores" description="Descubre los mejores bares & noche en puerto varas. Reseñas, precios y tips locales. Guía actualizada 2026.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">🍻</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Bares & Noche en puerto varas</h1>
      <p class="text-white/80 text-lg max-w-2xl">La guía más completa. Reseñas, precios y tips de locales.</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap gap-2 mb-8">
      {(items || []).map((item) => (
        <a href="/bares/{item.slug}" class="bg-gray-100 hover:bg-purple-100 text-gray-700 text-xs font-medium px-3 py-1.5 rounded-full transition-colors no-underline">
          {item.name}
        </a>
      ))}
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {(items || []).map((item) => (
        <a href="/bares/{item.slug}" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300">
          <div class="h-40 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center">
            <span class="text-4xl">🍻</span>
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <h2 class="font-bold text-gray-900">{item.name}</h2>
              <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">{item.priceRange || ''}</span>
            </div>
            <p class="text-gray-500 text-sm leading-relaxed mb-3">{item.shortDescription || ''}</p>
            <div class="flex items-center gap-2 text-sm">
              <span class="text-amber-500">{'★'.repeat(Math.round(item.rating || 4))}</span>
              <span class="text-gray-400 text-xs">({item.reviewCount || 0})</span>
            </div>
            {item.neighborhood && <p class="text-xs text-gray-400 mt-2">📍 {item.neighborhood}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>