        <a href="/bares/el-rincon-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-40 bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center"><span class="text-4xl">🍻</span></div><div class="p-5"><div class="flex items-center justify-between mb-2"><h2 class="font-bold text-gray-900 group-hover:text-purple-600 transition-colors">El Rincón</h2><span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">$$</span></div><p class="text-gray-500 text-sm leading-relaxed mb-3">Bar de copas íntimo con jazz los viernes.</p><div class="flex items-center gap-2 text-sm"><span class="text-amber-500">&#9733;&#9733;&#9733;&#9733;&#9733;</span><span class="text-gray-400 text-xs">(234)</span></div><p class="text-xs text-gray-400 mt-2">📍 centro</p></div></a>
        <a href="/bares/pub-1900-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-40 bg-gradient-to-br from-purple-100 to-pink-100 flex items-center justify-center"><span class="text-4xl">🍻</span></div><div class="p-5"><div class="flex items-center justify-between mb-2"><h2 class="font-bold text-gray-900 group-hover:text-purple-600 transition-colors">Pub 1900</h2><span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full">$$</span></div><p class="text-gray-500 text-sm leading-relaxed mb-3">Pub irlandés con más de 30 whiskeys y cerveza de barril.</p><div class="flex items-center gap-2 text-sm"><span class="text-amber-500">&#9733;&#9733;&#9733;&#9733;&#9734;</span><span class="text-gray-400 text-xs">(678)</span></div><p class="text-xs text-gray-400 mt-2">📍 centro</p></div></a>
