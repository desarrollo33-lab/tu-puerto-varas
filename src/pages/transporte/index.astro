---
import BaseLayout from '../../layouts/BaseLayout.astro';
const data = {"desde_santiago":[{"tipo":"Avion","duracion":"1h 45min","precio":"$35.000 - $120.000"},{"tipo":"Bus","duracion":"12 horas","precio":"$25.000 - $45.000"},{"tipo":"Auto","rutas":"Ruta 5 Sur + 225","combustible":"$35.000 ida"}],"transporte_local":[{"tipo":"Buses urbanos","cobertura":"Toda la ciudad","frecuencia":"15-30 min"},{"tipo":"Taxis","disponibilidad":"24/7","tarifa":"$350/km"},{"tipo":"Colectivos","rutas":"Sector metro","tarifa":"$500 - $2.000"},{"tipo":"Bicicleta","arriendo":"$8.000/dia","pistas":"Ciclovia costanera"}],"aeropuerto_cercano":{"nombre":"Aeropuerto El Tepual Puerto Montt","distancia":"25 km","vuelos_nacionales":"Santiago 5 diarios","vuelos_internacionales":"Conexion Santiago"},"terminal_buses":{"nombre":"Terminal Puerto Varas","destinos":["Santiago","Osorno","Puerto Montt","Frutillar"],"buses_rurales":"Colectivos sectoriales"},"faqs":[{"pregunta":"Como llegar desde el aeropuerto?","respuesta":"Buses cada 30 min o taxi $25.000."},{"pregunta":"Hay bencinera cerca?","respuesta":"Estaciones Unimarc,Shell,Copec en toda la ciudad."},{"pregunta":"Se puede caminar en la ciudad?","respuesta":"Centro y costanera 100% walkable."},{"pregunta":"Uber funciona?","respaccion":"Si, Uber y Cabify disponibles."},{"pregunta":"Estacionamiento gratis?","respuesta":"Zona turismo: primeras 2h gratis. Fuera: payant."}],"slug":"transporte"};
---
<BaseLayout title="Transporte puerto varas" description="Datos y comparativas de transporte en puerto varas">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">🚌</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Transporte</h1>
      <p class="text-white/80 text-lg max-w-2xl">Datos actualizados para puerto varas.</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">desde santiago</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">tipo</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">duracion</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">precio</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Avion</td><td class="py-2 px-3 text-sm text-gray-600">1h 45min</td><td class="py-2 px-3 text-sm text-gray-600">$35.000 - $120.000</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Bus</td><td class="py-2 px-3 text-sm text-gray-600">12 horas</td><td class="py-2 px-3 text-sm text-gray-600">$25.000 - $45.000</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Auto</td><td class="py-2 px-3 text-sm text-gray-600"></td><td class="py-2 px-3 text-sm text-gray-600"></td></tr></tbody></table></div></div>
        <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">transporte local</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">tipo</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">cobertura</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">frecuencia</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Buses urbanos</td><td class="py-2 px-3 text-sm text-gray-600">Toda la ciudad</td><td class="py-2 px-3 text-sm text-gray-600">15-30 min</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Taxis</td><td class="py-2 px-3 text-sm text-gray-600"></td><td class="py-2 px-3 text-sm text-gray-600"></td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Colectivos</td><td class="py-2 px-3 text-sm text-gray-600"></td><td class="py-2 px-3 text-sm text-gray-600"></td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Bicicleta</td><td class="py-2 px-3 text-sm text-gray-600"></td><td class="py-2 px-3 text-sm text-gray-600"></td></tr></tbody></table></div></div>
        <div class="mb-8 bg-gray-50 rounded-xl p-6"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">aeropuerto cercano</h2><div><div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">nombre</span><span class="font-medium text-gray-900 text-sm">Aeropuerto El Tepual Puerto Montt</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">distancia</span><span class="font-medium text-gray-900 text-sm">25 km</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">vuelos nacionales</span><span class="font-medium text-gray-900 text-sm">Santiago 5 diarios</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">vuelos internacionales</span><span class="font-medium text-gray-900 text-sm">Conexion Santiago</span></div></div></div>
        <div class="mb-8 bg-gray-50 rounded-xl p-6"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">terminal buses</h2><div><div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">nombre</span><span class="font-medium text-gray-900 text-sm">Terminal Puerto Varas</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">destinos</span><span class="font-medium text-gray-900 text-sm">Santiago,Osorno,Puerto Montt,Frutillar</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">buses rurales</span><span class="font-medium text-gray-900 text-sm">Colectivos sectoriales</span></div></div></div>
    <div class="mt-12"><h2 class="text-2xl font-bold text-gray-900 mb-4">Preguntas Frecuentes</h2><details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details></div>
    <div class="mt-8 text-center">
      <a href="https://tucorretaje.cl" target="_blank" class="inline-flex items-center gap-2 text-white font-bold px-6 py-3 rounded-xl no-underline hover:opacity-90 transition-opacity" style="background: #6D28D9;">🏠 Ver propiedades en puerto varas</a>
    </div>
  </section>
</BaseLayout>