---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Colegios puerto varas | Directorio completo" description="Directorio completo de colegios en puerto varas. Direcciones, telefonos y horarios.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">🎓</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Colegios</h1>
      <p class="text-white/80 text-lg">Direcciones, telefonos y horarios.</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" set:html={`<div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Colegio Puerto Varas</h2><span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">municipal</span></div><p class="text-gray-500 text-sm mb-1">📍 San Francisco 345, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 223 4567</p><p class="text-gray-400 text-xs mt-2">Centro</p></div>
      <div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Colegio Bicentenario Puerto Varas</h2><span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">subvencionado</span></div><p class="text-gray-500 text-sm mb-1">📍 Walker Martínez 890, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 223 1890</p><p class="text-gray-400 text-xs mt-2">Villa Los Ulmos</p></div>
      <div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Colegio San José</h2><span class="text-xs px-2 py-0.5 rounded-full bg-green-100 text-green-700">subvencionado</span></div><p class="text-gray-500 text-sm mb-1">📍 O'Higgins 1234, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 223 3456</p><p class="text-gray-400 text-xs mt-2">Centro</p></div>
      <div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Liceo Comercial de Puerto Varas</h2><span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">municipal</span></div><p class="text-gray-500 text-sm mb-1">📍 Avenida Puerto Varas 567, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 223 7890</p><p class="text-gray-400 text-xs mt-2">Puerto Chico</p></div>
      <div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Colegio Alemanal Puerto Varas</h2><span class="text-xs px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">privado</span></div><p class="text-gray-500 text-sm mb-1">📍 Camino Ensenada Km 3, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 248 1234</p><p class="text-gray-400 text-xs mt-2">Ensenada</p></div>
      <div class="bg-white border border-gray-100 rounded-xl p-5 hover:shadow-md transition-shadow"><div class="flex items-start justify-between mb-2"><h2 class="font-bold text-gray-900">Colegio Cumbres Puerto Varas</h2><span class="text-xs px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">privado</span></div><p class="text-gray-500 text-sm mb-1">📍 Sector Champulli, Puerto Varas</p><p class="text-gray-500 text-sm mb-1">📞 +56 65 248 5678</p><p class="text-gray-400 text-xs mt-2">Champulli</p></div>`}></div>
  </section>
</BaseLayout>