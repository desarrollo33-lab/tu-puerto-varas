const item = items.find((i) => i.slug === 'lomas-del-lago-puerto-varas-barrio') || {"slug":"lomas-del-lago-puerto-varas-barrio","name":"Lomas del Lago","zone":"Residencial Premium","neighborhoods":["Lomas Phase 1","Lomas Phase 2","Sector Colegio","Sector Tranque"],"landmarks":["Club de Golf Puerto Varas","Colegio Alemán","Centro Comercial Lomas"],"geo":{"lat":-41.3085,"lng":-72.9785},"vibe":"Residencial tranquilo y exclusivo","costo_arriendo":"$500.000 - $900.000 CLP/mes","idealPara":["familias","expatriados","tranquilo","golf"],"heroTitle":"El Sector Residencial con Vistas","heroSubtitle":"Barrio tranquilo con servicios y vista privilegiada","sections":[{"title":"Vivienda y Urbanismo","content":"Lomas del Lago es un barrio residencial planificado con vivienda unifamiliar y departamentos. El sector ofrece tranquilidad sin sacrificar conectividad: está a 10 minutos del centro en auto. Los neighborhood tienen vigilancia privada y áreas verdes comunes."},{"title":"Servicios y Comercio","content":"El barrio cuenta con strip mall, farmacia, restaurant, gym y clínica. El Colegio Alemán de Puerto Varas tiene在这儿校区 para familias con hijos. El Centro Comercial Lomas offrece comercio básico sin necesidad de ir al centro."},{"title":"Actividades Recreativas","content":"El Club de Golf Puerto Varas offrece 18 hoyos con vista al volcan. El sector tiene ciclovías y parques infantiles. Es común ver familias caminando, cyclists y runners por las mañanas."}],"highlights":["Vivienda residencial tranquila","Golf con vista al volcan","Servicios completos en el barrio","Colegio alemán en el sector","Seguridad 24/7"],"tips":["Ideal para familias con niños","El sector está en altura, algunas casas tienen vista lago","El Colegio Alemán atrae familias expatriadas"],"warnings":["Necesitas auto para mayor comodidad"],"faqs":[{"pregunta":"¿Hay transporte público?","respuesta":"Hay buses y colectivos pero es limitado. Auto es más práctico."},{"pregunta":"¿Qué precios tienen las casas?","respuesta":"Varian mucho: departamentos desde $80M CLP, casas desde $150M CLP."}]};
---
<BaseLayout title="El Sector Residencial con Vistas | Barrios puerto varas" description="Barrio tranquilo con servicios y vista privilegiada">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href="/barrios" class="text-white/70 text-sm hover:text-white no-underline mb-4 inline-block">← Volver a Barrios</a>
      <h1 class="text-3xl lg:text-4xl font-black text-white mb-2">El Sector Residencial con Vistas</h1>
      <p class="text-white/80 text-lg">Barrio tranquilo con servicios y vista privilegiada</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Vivienda y Urbanismo</h2><div class="text-gray-600 leading-relaxed prose max-w-none">Lomas del Lago es un barrio residencial planificado con vivienda unifamiliar y departamentos. El sector ofrece tranquilidad sin sacrificar conectividad: está a 10 minutos del centro en auto. Los neighborhood tienen vigilancia privada y áreas verdes comunes.</div></div>
          <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Servicios y Comercio</h2><div class="text-gray-600 leading-relaxed prose max-w-none">El barrio cuenta con strip mall, farmacia, restaurant, gym y clínica. El Colegio Alemán de Puerto Varas tiene在这儿校区 para familias con hijos. El Centro Comercial Lomas offrece comercio básico sin necesidad de ir al centro.</div></div>
          <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Actividades Recreativas</h2><div class="text-gray-600 leading-relaxed prose max-w-none">El Club de Golf Puerto Varas offrece 18 hoyos con vista al volcan. El sector tiene ciclovías y parques infantiles. Es común ver familias caminando, cyclists y runners por las mañanas.</div></div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Preguntas Frecuentes</h2><details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
      </div>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-4">
          <h4 class="font-semibold text-sm text-gray-900 mb-3">📋 Info Práctica</h4>
          
          
          
          
          
        </div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-3">⭐ Highlights</h4><ul class="space-y-1"><li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Vivienda residencial tranquila</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Golf con vista al volcan</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Servicios completos en el barrio</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Colegio alemán en el sector</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Seguridad 24/7</li></ul></div>
        <div class="bg-purple-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-purple-900 mb-3">💡 Tips</h4><ul class="space-y-2"><li class="text-gray-600 text-sm">💡 Ideal para familias con niños</li>
          <li class="text-gray-600 text-sm">💡 El sector está en altura, algunas casas tienen vista lago</li>
          <li class="text-gray-600 text-sm">💡 El Colegio Alemán atrae familias expatriadas</li></ul></div>
        <div class="bg-amber-50 border border-amber-100 rounded-xl p-4"><h4 class="font-semibold text-sm text-amber-900 mb-3">⚠️ Precauciones</h4><ul class="space-y-1"><li class="text-amber-700 text-sm">Necesitas auto para mayor comodidad</li></ul></div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">🎭 Vibra</h4><p class="text-gray-600 text-sm">Residencial tranquilo y exclusivo</p></div>
