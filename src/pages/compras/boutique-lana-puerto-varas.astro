---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catListing } from '../../data/content';
const items = catListing['compras'] || [];
const item = items.find((i) => i.slug === 'boutique-lana-puerto-varas') || {"slug":"boutique-lana-puerto-varas","name":"Boutique de Lana Austral","category_slug":"compras","shortDescription":"Ropa y accesorios en lana de oveja y alpaca de producers locales.","rating":4.6,"reviewCount":234,"priceRange":"$$$","address":"Costanera 890, Puerto Varas","tags":["lana","ropa","local"],"tip":"Los sueters de lana merino duran generaciones.","bestFor":"moda","season":"todo-el-año","neighborhood":"costanera"};
---
<BaseLayout title="Boutique de Lana Austral | Compras & Artesanía puerto varas" description="Ropa y accesorios en lana de oveja y alpaca de producers locales.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href="/compras" class="text-white/70 text-sm hover:text-white no-underline mb-4 inline-block">← Volver a Compras & Artesanía</a>
      <h1 class="text-3xl lg:text-4xl font-black text-white mb-2">Boutique de Lana Austral</h1>
      <div class="flex flex-wrap items-center gap-3 text-white/80 text-sm mt-4">
        <span class="text-amber-300">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>({item.reviewCount || 0} reseñas)</span>
        <span class="bg-white/20 px-3 py-1 rounded-full">$$$</span>
        <span>📍 costanera</span>
      </div>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="h-64 bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl flex items-center justify-center mb-8">
          <span class="text-6xl">🛍️</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Sobre Boutique de Lana Austral</h2>
        <p class="text-gray-600 leading-relaxed mb-6">Ropa y accesorios en lana de oveja y alpaca de producers locales.</p>
        
        
        <div class="flex flex-wrap gap-2 mt-6">
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">lana</span>
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">ropa</span>
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">local</span>
        </div>
      </div>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">📍 Dirección</h4><p class="text-gray-600 text-sm">Costanera 890, Puerto Varas</p></div>
        
        <div class="bg-gray-50 rounded-xl p-4">
          <h4 class="font-semibold text-sm text-gray-900 mb-1">💰 Precio</h4>
          <p class="text-gray-600 text-sm">$$$</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">👥 Ideal para</h4><p class="text-gray-600 text-sm">moda</p></div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">🗓️ Temporada</h4><p class="text-gray-600 text-sm">todo-el-año</p></div>
        <div class="bg-purple-50 border border-purple-100 rounded-xl p-4"><h4 class="font-semibold text-sm text-purple-900 mb-1">💡 Tip local</h4><p class="text-purple-700 text-sm">Los sueters de lana merino duran generaciones.</p></div>
        <a href="https://tucorretaje.cl" target="_blank" class="block text-center text-white font-bold py-3 rounded-xl no-underline hover:opacity-90 transition-opacity" style="background: #6D28D9;">🏠 Ver propiedades en puerto varas</a>
      </div>
    </div>
  </section>
</BaseLayout>