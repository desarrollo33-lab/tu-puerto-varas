---
import BaseLayout from '../../layouts/BaseLayout.astro';
const data = {"proveedores":[{"operadora":"Movistar","cobertura":"4G LTE","disponibilidad":"95%"},{"operadora":"Entel","cobertura":"4G LTE","disponibilidad":"98%"},{"operadora":"Claro","cobertura":"4G LTE","disponibilidad":"90%"},{"operadora":"WOM","cobertura":"4G","disponibilidad":"85%"}],"wifi_publico":[{"lugar":"Plaza de Armas","velocidad":"20 Mbps"},{"lugar":"Costanera","velocidad":"15 Mbps"},{"lugar":"Mercado Municipal","velocidad":"10 Mbps"}],"coworking_spaces":[{"nombre":"Territorio Cowork","wifi":"100 Mbps","precio_dia":"$8.000"},{"nombre":"Hub Puerto Varas","wifi":"50 Mbps","precio_dia":"$12.000"},{"nombre":"Coffee Work","wifi":"30 Mbps","precio_dia":"$6.000"}],"faqs":[{"pregunta":"Hay buena conexion para trabajar remoto?","respuesta":"Si, 4G LTE y wifi en cafes. Coworking disponibles."},{"pregunta":"Internet fiber optica?","respuesta":"Fibra/optica en zonas nuevas. ADSL en sector antiguo."},{"pregunta":"Roaming desde Argentina?","respuesta":"Funciona igual, precios internacionales."},{"pregunta":"Donde wifi gratuito?","respuesta":"Plaza de Armas,Costanera,Mercado."},{"pregunta":"Celular funciona todo el sector?","respuesta":"4G centro, 3G sectores rurales."}],"slug":"conectividad"};
---
<BaseLayout title="Internet & Cowork puerto varas" description="Datos y comparativas de internet & cowork en puerto varas">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">📡</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Internet & Cowork</h1>
      <p class="text-white/80 text-lg max-w-2xl">Datos actualizados para puerto varas.</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">proveedores</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">operadora</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">cobertura</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">disponibilidad</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Movistar</td><td class="py-2 px-3 text-sm text-gray-600">4G LTE</td><td class="py-2 px-3 text-sm text-gray-600">95%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Entel</td><td class="py-2 px-3 text-sm text-gray-600">4G LTE</td><td class="py-2 px-3 text-sm text-gray-600">98%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Claro</td><td class="py-2 px-3 text-sm text-gray-600">4G LTE</td><td class="py-2 px-3 text-sm text-gray-600">90%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">WOM</td><td class="py-2 px-3 text-sm text-gray-600">4G</td><td class="py-2 px-3 text-sm text-gray-600">85%</td></tr></tbody></table></div></div>
        <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">wifi publico</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">lugar</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">velocidad</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Plaza de Armas</td><td class="py-2 px-3 text-sm text-gray-600">20 Mbps</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Costanera</td><td class="py-2 px-3 text-sm text-gray-600">15 Mbps</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Mercado Municipal</td><td class="py-2 px-3 text-sm text-gray-600">10 Mbps</td></tr></tbody></table></div></div>
        <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">coworking spaces</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">nombre</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">wifi</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">precio dia</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Territorio Cowork</td><td class="py-2 px-3 text-sm text-gray-600">100 Mbps</td><td class="py-2 px-3 text-sm text-gray-600">$8.000</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Hub Puerto Varas</td><td class="py-2 px-3 text-sm text-gray-600">50 Mbps</td><td class="py-2 px-3 text-sm text-gray-600">$12.000</td></tr>
