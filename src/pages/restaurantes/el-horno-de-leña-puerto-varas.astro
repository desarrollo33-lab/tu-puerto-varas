---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catListing } from '../../data/content';
const items = catListing['restaurantes'] || [];
const item = items.find((i) => i.slug === 'el-horno-de-leña-puerto-varas') || {"slug":"el-horno-de-leña-puerto-varas","name":"El Horno de Leña","category_slug":"restaurantes","shortDescription":"Pizzas artesanales horneadas en leña con ingredientes locales.","rating":4.3,"reviewCount":567,"priceRange":"$$","address":"San Francisco 234, Puerto Varas","tags":["pizza","horno-leña","artesanal","familiar"],"features":["Leña/quinoa","Massa grossa","Cerveza artesanal","Terraza"],"tip":"La pizza de choros y cholgas es única en la ciudad.","bestFor":"familias","season":"todo-el-año","neighborhood":"alam"};
---
<BaseLayout title="El Horno de Leña | Restaurantes puerto varas" description="Pizzas artesanales horneadas en leña con ingredientes locales.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href="/restaurantes" class="text-white/70 text-sm hover:text-white no-underline mb-4 inline-block">← Volver a Restaurantes</a>
      <h1 class="text-3xl lg:text-4xl font-black text-white mb-2">El Horno de Leña</h1>
      <div class="flex flex-wrap items-center gap-3 text-white/80 text-sm mt-4">
        <span class="text-amber-300">&#9733;&#9733;&#9733;&#9733;&#9734;</span>
        <span>({item.reviewCount || 0} reseñas)</span>
        <span class="bg-white/20 px-3 py-1 rounded-full">$$</span>
        <span>📍 alam</span>
      </div>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="h-64 bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl flex items-center justify-center mb-8">
          <span class="text-6xl">🍽️</span>
        </div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Sobre El Horno de Leña</h2>
        <p class="text-gray-600 leading-relaxed mb-6">Pizzas artesanales horneadas en leña con ingredientes locales.</p>
        
        <h3 class="text-xl font-bold text-gray-900 mb-3">Lo mejor</h3>
        <ul class="space-y-2 mb-6">
          <li class="flex items-start gap-2 text-gray-600"><span class="text-green-500 mt-1">✓</span> Leña/quinoa</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-green-500 mt-1">✓</span> Massa grossa</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-green-500 mt-1">✓</span> Cerveza artesanal</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-green-500 mt-1">✓</span> Terraza</li>
        </ul>
        
        <div class="flex flex-wrap gap-2 mt-6">
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">pizza</span>
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">horno-leña</span>
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">artesanal</span>
          <span class="bg-gray-100 text-gray-600 text-xs px-3 py-1 rounded-full">familiar</span>
        </div>
      </div>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">📍 Dirección</h4><p class="text-gray-600 text-sm">San Francisco 234, Puerto Varas</p></div>
        
        <div class="bg-gray-50 rounded-xl p-4">
          <h4 class="font-semibold text-sm text-gray-900 mb-1">💰 Precio</h4>
          <p class="text-gray-600 text-sm">$$</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">👥 Ideal para</h4><p class="text-gray-600 text-sm">familias</p></div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-1">🗓️ Temporada</h4><p class="text-gray-600 text-sm">todo-el-año</p></div>
        <div class="bg-purple-50 border border-purple-100 rounded-xl p-4"><h4 class="font-semibold text-sm text-purple-900 mb-1">💡 Tip local</h4><p class="text-purple-700 text-sm">La pizza de choros y cholgas es única en la ciudad.</p></div>
        <a href="https://tucorretaje.cl" target="_blank" class="block text-center text-white font-bold py-3 rounded-xl no-underline hover:opacity-90 transition-opacity" style="background: #6D28D9;">🏠 Ver propiedades en puerto varas</a>
      </div>
    </div>
  </section>
</BaseLayout>