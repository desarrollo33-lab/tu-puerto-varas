          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details></div>
    <div class="text-center bg-gray-50 rounded-2xl p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">¿Listo para dar el paso?</h2>
      <p class="text-gray-600 mb-6">Explora propiedades disponibles en puerto varas y sus alrededores.</p>
      <a href="https://tucorretaje.cl" target="_blank"
        class="inline-flex items-center gap-2 text-white font-bold px-8 py-4 rounded-xl no-underline text-lg hover:opacity-90 transition-opacity"
        style="background: #6D28D9;">
        Ver propiedades disponibles
      </a>
    </div>
  </section>
</BaseLayout>