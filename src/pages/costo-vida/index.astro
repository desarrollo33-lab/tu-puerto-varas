---
<BaseLayout title="Costo de Vida puerto varas" description="Datos y comparativas de costo de vida en puerto varas">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">💰</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Costo de Vida</h1>
      <p class="text-white/80 text-lg max-w-2xl">Datos actualizados para puerto varas.</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">categorias costo</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">categoria</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">rango clp</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">vs santiago</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Arriendo Depto Centro</td><td class="py-2 px-3 text-sm text-gray-600">$280.000 - $450.000</td><td class="py-2 px-3 text-sm text-gray-600">-15%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Arriendo Depto Costanera</td><td class="py-2 px-3 text-sm text-gray-600">$350.000 - $600.000</td><td class="py-2 px-3 text-sm text-gray-600">+5%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Menu restaurant economico</td><td class="py-2 px-3 text-sm text-gray-600">$5.500 - $8.000</td><td class="py-2 px-3 text-sm text-gray-600">+10%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600"></td><td class="py-2 px-3 text-sm text-gray-600">$350 - $450</td><td class="py-2 px-3 text-sm text-gray-600">mismo precio</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Supermercado mensual</td><td class="py-2 px-3 text-sm text-gray-600">$250.000 - $350.000</td><td class="py-2 px-3 text-sm text-gray-600">-5%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Cerveza artesanal</td><td class="py-2 px-3 text-sm text-gray-600">$3.500 - $5.000</td><td class="py-2 px-3 text-sm text-gray-600">+20%</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Hotel 3 estrellas/noche</td><td class="py-2 px-3 text-sm text-gray-600">$45.000 - $80.000</td><td class="py-2 px-3 text-sm text-gray-600">+15%</td></tr></tbody></table></div></div>
        <div class="mb-8 bg-gray-50 rounded-xl p-6"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">costo vida mensual</h2><div><div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">presupuesto minimo</span><span class="font-medium text-gray-900 text-sm">$600.000 CLP</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">presupuesto medio</span><span class="font-medium text-gray-900 text-sm">$1.200.000 CLP</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">presupuesto premium</span><span class="font-medium text-gray-900 text-sm">$2.500.000 CLP</span></div></div></div>
        <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">comparativa ciudades</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">ciudad</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">costo</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">indice</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Puerto Varas</td><td class="py-2 px-3 text-sm text-gray-600">Medio</td><td class="py-2 px-3 text-sm text-gray-600">95</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Santiago</td><td class="py-2 px-3 text-sm text-gray-600">Medio-alto</td><td class="py-2 px-3 text-sm text-gray-600">100</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Puerto Montt</td><td class="py-2 px-3 text-sm text-gray-600">Economico</td><td class="py-2 px-3 text-sm text-gray-600">85</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Bariloche Argentina</td><td class="py-2 px-3 text-sm text-gray-600">Alto</td><td class="py-2 px-3 text-sm text-gray-600">110</td></tr></tbody></table></div></div>
    <div class="mt-12"><h2 class="text-2xl font-bold text-gray-900 mb-4">Preguntas Frecuentes</h2><details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
