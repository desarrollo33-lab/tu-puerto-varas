---
import BaseLayout from '../../layouts/BaseLayout.astro';
const data = {"seasons":[{"nombre":"Verano","meses":"Diciembre a Febrero","temp_min":"12°C","temp_max":"25°C","lluvia_mm":"45mm","que_empacar":["ropa ligera","bloqueador solar","cortavientos","zapatos comodos"]},{"nombre":"Otono","meses":"Marzo a Mayo","temp_min":"8°C","temp_max":"18°C","lluvia_mm":"180mm","que_empacar":["capas","paragua","cortavientos","sueter"]},{"nombre":"Invierno","meses":"Junio a Agosto","temp_min":"3°C","temp_max":"12°C","lluvia_mm":"320mm","que_empacar":["abrigo impermeable","guantes","bufanda","botas de agua"]},{"nombre":"Primavera","meses":"Septiembre a Noviembre","temp_min":"7°C","temp_max":"16°C","lluvia_mm":"120mm","que_empacar":["capas","chaqueta","zapatos waterproof","protector solar"]}],"datos_anuales":{"temperatura_promedio":"11°C","lluvia_anual":"2000mm","humedad":"85%","horas_sol":"1800 horas/ano","viento":"25 km/h promedio"},"comparativa_ciudades":[{"ciudad":"Puerto Varas","clima":"Templado lluvioso","lluvia":"2000mm","ventaja":"Vegetacion verde todo el ano"},{"ciudad":"Santiago","clima":"Semiarido","lluvia":"312mm","ventaja":"Mas sol, menos lluvia"},{"ciudad":"Valparaiso","clima":"Mediterraneo","lluvia":"450mm","ventaja":"Clima mas seco"},{"ciudad":"Punta Arenas","clima":"Subartico","lluvia":"450mm","ventaja":"Mas sol en verano"}],"faqs":[{"pregunta":"Cuando es la mejor epoca para visitar Puerto Varas?","respuesta":"Entre diciembre y marzo por el clima mas seco y dias largos, ideal para tours y trekking."},{"pregunta":"Llueve mucho en Puerto Varas?","respuesta":"Si, es una de las ciudades mas lluviosas de Chile. Precipitacion: 2000mm anuales. Lleva siempre impermeable."},{"pregunta":"Puedo ver el volcan Osorno nevado?","respuesta":"El volcan Osorno tiene nieves perpetuas. En invierno (junio-agosto) se ve completamente nevado desde la ciudad."},{"pregunta":"Cual es el mejor clima para fotografia?","respuesta":"Octubre-abril, dias largos con 18+ horas de luz y menos lluvia."},{"pregunta":"El viento afecta las actividades?","respuesta":"Si, el viento del lago es frecuente. Kayak y sailing mejor en manana temprano."}],"slug":"clima"};
---
<BaseLayout title="Clima puerto varas" description="Datos y comparativas de clima en puerto varas">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">🌤️</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Clima</h1>
      <p class="text-white/80 text-lg max-w-2xl">Datos actualizados para puerto varas.</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">seasons</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">nombre</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">meses</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">temp min</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">temp max</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">lluvia mm</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">que empacar</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Verano</td><td class="py-2 px-3 text-sm text-gray-600">Diciembre a Febrero</td><td class="py-2 px-3 text-sm text-gray-600">12°C</td><td class="py-2 px-3 text-sm text-gray-600">25°C</td><td class="py-2 px-3 text-sm text-gray-600">45mm</td><td class="py-2 px-3 text-sm text-gray-600">ropa ligera,bloqueador solar,cortavientos,zapatos comodos</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Otono</td><td class="py-2 px-3 text-sm text-gray-600">Marzo a Mayo</td><td class="py-2 px-3 text-sm text-gray-600">8°C</td><td class="py-2 px-3 text-sm text-gray-600">18°C</td><td class="py-2 px-3 text-sm text-gray-600">180mm</td><td class="py-2 px-3 text-sm text-gray-600">capas,paragua,cortavientos,sueter</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Invierno</td><td class="py-2 px-3 text-sm text-gray-600">Junio a Agosto</td><td class="py-2 px-3 text-sm text-gray-600">3°C</td><td class="py-2 px-3 text-sm text-gray-600">12°C</td><td class="py-2 px-3 text-sm text-gray-600">320mm</td><td class="py-2 px-3 text-sm text-gray-600">abrigo impermeable,guantes,bufanda,botas de agua</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Primavera</td><td class="py-2 px-3 text-sm text-gray-600">Septiembre a Noviembre</td><td class="py-2 px-3 text-sm text-gray-600">7°C</td><td class="py-2 px-3 text-sm text-gray-600">16°C</td><td class="py-2 px-3 text-sm text-gray-600">120mm</td><td class="py-2 px-3 text-sm text-gray-600">capas,chaqueta,zapatos waterproof,protector solar</td></tr></tbody></table></div></div>
        <div class="mb-8 bg-gray-50 rounded-xl p-6"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">datos anuales</h2><div><div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">temperatura promedio</span><span class="font-medium text-gray-900 text-sm">11°C</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">lluvia anual</span><span class="font-medium text-gray-900 text-sm">2000mm</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">humedad</span><span class="font-medium text-gray-900 text-sm">85%</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">horas sol</span><span class="font-medium text-gray-900 text-sm">1800 horas/ano</span></div>
            <div class="flex justify-between py-2 border-b border-gray-50"><span class="text-gray-500 text-sm capitalize">viento</span><span class="font-medium text-gray-900 text-sm">25 km/h promedio</span></div></div></div>
        <div class="mb-8"><h2 class="text-xl font-bold text-gray-900 mb-3 capitalize">comparativa ciudades</h2><div class="overflow-x-auto"><table class="w-full"><thead><tr class="bg-gray-50"><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">ciudad</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">clima</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">lluvia</th><th class="py-2 px-3 text-left text-xs font-semibold text-gray-500 uppercase">ventaja</th></tr></thead><tbody><tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Puerto Varas</td><td class="py-2 px-3 text-sm text-gray-600">Templado lluvioso</td><td class="py-2 px-3 text-sm text-gray-600">2000mm</td><td class="py-2 px-3 text-sm text-gray-600">Vegetacion verde todo el ano</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Santiago</td><td class="py-2 px-3 text-sm text-gray-600">Semiarido</td><td class="py-2 px-3 text-sm text-gray-600">312mm</td><td class="py-2 px-3 text-sm text-gray-600">Mas sol, menos lluvia</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Valparaiso</td><td class="py-2 px-3 text-sm text-gray-600">Mediterraneo</td><td class="py-2 px-3 text-sm text-gray-600">450mm</td><td class="py-2 px-3 text-sm text-gray-600">Clima mas seco</td></tr>
            <tr class="border-b border-gray-50"><td class="py-2 px-3 text-sm text-gray-600">Punta Arenas</td><td class="py-2 px-3 text-sm text-gray-600">Subartico</td><td class="py-2 px-3 text-sm text-gray-600">450mm</td><td class="py-2 px-3 text-sm text-gray-600">Mas sol en verano</td></tr></tbody></table></div></div>
    <div class="mt-12"><h2 class="text-2xl font-bold text-gray-900 mb-4">Preguntas Frecuentes</h2><details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details></div>
    <div class="mt-8 text-center">
      <a href="https://tucorretaje.cl" target="_blank" class="inline-flex items-center gap-2 text-white font-bold px-6 py-3 rounded-xl no-underline hover:opacity-90 transition-opacity" style="background: #6D28D9;">🏠 Ver propiedades en puerto varas</a>
    </div>
  </section>
</BaseLayout>