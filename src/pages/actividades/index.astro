<BaseLayout title="Qué Hacer en puerto varas | Los mejores" description="Descubre los mejores qué hacer en puerto varas. Reseñas, precios y tips locales. Guía actualizada 2026.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
