---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catListing } from '../../data/content';
const items = catListing['actividades'] || [];
const item = items.find((i) => i.slug === 'visita-saltos-petrohue-puerto-varas') || {"slug":"visita-saltos-petrohue-puerto-varas","name":"Saltos de Petrohué","category_slug":"actividades","shortDescription":"Cascadas de agua turquesa en el Parque Nacional Vicente Perez Rosales.","rating":4.9,"reviewCount":2345,"priceRange":"$","address":"Parque Nacional Vicente Perez Rosales, Puerto Varas","tags":["cascadas","naturaleza","parque"],"tip":"Comprar entrada online evita la fila en temporada alta.","bestFor":"naturaleza","season":"todo-el-año","neighborhood":"petrohue"};
---
<BaseLayout title="Saltos de Petrohué | Qué Hacer puerto varas" description="Cascadas de agua turquesa en el Parque Nacional Vicente Perez Rosales.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href="/actividades" class="text-white/70 text-sm hover:text-white no-underline mb-4 inline-block">← Volver a Qué Hacer</a>
      <h1 class="text-3xl lg:text-4xl font-black text-white mb-2">Saltos de Petrohué</h1>
      <div class="flex flex-wrap items-center gap-3 text-white/80 text-sm mt-4">
        <span class="text-amber-300">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span>({item.reviewCount || 0} reseñas)</span>
        <span class="bg-white/20 px-3 py-1 rounded-full">$</span>
        <span>📍 petrohue</span>
      </div>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="h-64 bg-gradient-to-br from-purple-50 to-pink-50 rounded-2xl flex items-center justify-center mb-8">
