---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Alrededores puerto varas | Guias completas" description="Guias completas de alrededores en puerto varas. Informacion actualizada con tips locales.">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
      <span class="text-5xl mb-4 block">📍</span>
      <h1 class="text-4xl lg:text-5xl font-black text-white mb-4">Alrededores</h1>
      <p class="text-white/80 text-lg max-w-2xl">Todo lo que necesitas saber antes de ir.</p>
    </div>
  </section>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6" set:html={`<a href="/alrededores/frutillar-desde-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-48 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center relative"><span class="text-5xl">📍</span><span class="absolute top-3 right-3 bg-white/90 text-xs font-medium px-2 py-1 rounded-full">Fácil</span></div><div class="p-6"><h2 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition-colors mb-2">La Ciudad Alemana a 30 Minutos</h2><p class="text-gray-500 text-sm leading-relaxed mb-4">Pueblo patrimonial con arquitectura bávara y fábricas de chocolate</p><div class="flex flex-wrap gap-2"><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">⏱️ Medio día a día completo</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">📍 35 km (40 minutos)</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">🗓️ Todo el año</span></div></div></a>
      <a href="/alrededores/puerto-octay-desde-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-48 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center relative"><span class="text-5xl">📍</span><span class="absolute top-3 right-3 bg-white/90 text-xs font-medium px-2 py-1 rounded-full">Fácil</span></div><div class="p-6"><h2 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition-colors mb-2">El Fin del Lago Llanquihue</h2><p class="text-gray-500 text-sm leading-relaxed mb-4">Pueblo pescador con historia alemana y vistas al volcan</p><div class="flex flex-wrap gap-2"><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">⏱️ Medio día</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">📍 55 km (1 hora)</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">🗓️ Todo el año</span></div></div></a>
      <a href="/alrededores/ensenada-desde-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-48 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center relative"><span class="text-5xl">📍</span><span class="absolute top-3 right-3 bg-white/90 text-xs font-medium px-2 py-1 rounded-full">Fácil</span></div><div class="p-6"><h2 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition-colors mb-2">Donde Empieza la Patagonia</h2><p class="text-gray-500 text-sm leading-relaxed mb-4">Sector inicio de aventuras hacia el Volcán Osorno y Petrohué</p><div class="flex flex-wrap gap-2"><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">⏱️ 2-3 horas o base para tours</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">📍 45 km (1 hora)</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">🗓️ Todo el año</span></div></div></a>
      <a href="/alrededores/caleta-la-arena-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-48 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center relative"><span class="text-5xl">📍</span><span class="absolute top-3 right-3 bg-white/90 text-xs font-medium px-2 py-1 rounded-full">Fácil</span></div><div class="p-6"><h2 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition-colors mb-2">Playas Negras de Arena Fina</h2><p class="text-gray-500 text-sm leading-relaxed mb-4">Playas únicas con arena volcánica negra y bosque costero</p><div class="flex flex-wrap gap-2"><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">⏱️ 3-4 horas</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">📍 20 km (25 minutos)</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">🗓️ Todo el año (ballenas mayo-octubre)</span></div></div></a>
      <a href="/alrededores/rio-petuhue-puerto-varas" class="group block bg-white border border-gray-100 rounded-2xl overflow-hidden no-underline hover:shadow-xl transition-all duration-300"><div class="h-48 bg-gradient-to-br from-purple-50 to-pink-50 flex items-center justify-center relative"><span class="text-5xl">📍</span><span class="absolute top-3 right-3 bg-white/90 text-xs font-medium px-2 py-1 rounded-full">Variable según actividad</span></div><div class="p-6"><h2 class="font-bold text-xl text-gray-900 group-hover:text-purple-600 transition-colors mb-2">Aguas Esmeraldas de Origen Volcánico</h2><p class="text-gray-500 text-sm leading-relaxed mb-4">Kayak, pesca y senderismo en el río de los colores</p><div class="flex flex-wrap gap-2"><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">⏱️ Día completo</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">📍 80 km (1.5 horas)</span><span class="bg-gray-100 text-gray-600 text-xs px-2 py-1 rounded-full">🗓️ Octubre a abril</span></div></div></a>`}></div>
  </section>
</BaseLayout>