---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { catGuide } from '../../data/content';
const items = catGuide['alrededores'] || [];
const item = items.find((i) => i.slug === 'caleta-la-arena-puerto-varas') || {"slug":"caleta-la-arena-puerto-varas","name":"Caleta La Arena","heroTitle":"Playas Negras de Arena Fina","heroSubtitle":"Playas únicas con arena volcánica negra y bosque costero","sections":[{"title":"Playas de Arena Negra","content":"Caleta La Arena es conocida por sus playas de arena negra成因 por la erosión volcánica de los cerros circundantes. A diferencia de las playas típicas, la arena volcánica tiene una textura única que contrasta dramáticamente con el verde del bosque y el azul del Pacífico. Es uno de los fenómenos naturales más拍照-impresionantes de la zona."},{"title":"Pesca Artesanal y Pueblo Costero","content":"La caleta es un pueblo pesquero activo donde puedes observar el desembarco de la pesca del día. Los pescadores salen en la madrugada y regresan con corvina, robalo y reineta. Puedes comprar pescado fresco directo del bote a precios increibles. El pueblo tiene cocinerías simples donde sirven empanadas de jaiba y mariscos."},{"title":"Biodiversidad Marina","content":"Las aguas de Caleta La Arena son ricas en vida marina. Es común ver delfines cerca de la costa y, en temporada, ballenas grises migrando por el Pacífico. Los avistamientos de aves marinas incluyen albatros, pelícanos y gaviotas australes. El bosque costero adjacent protege poblaciones de nutrias marinas."}],"practicalInfo":{"distancia_desde_pv":"20 km (25 minutos)","dificultad":"Fácil","duracion_estimada":"3-4 horas","mejor_epoca":"Todo el año (ballenas mayo-octubre)","costo_entrada":"Gratis"},"highlights":["Playas de arena negra volcánica","Pesca fresca directo del bote","Avistamiento de ballenas grises","Cocinerías de mariscos auténticas","Bosque costero prístino"],"tips":["Compra pescado fresco en la mañana","LlevaBlock para picnic en la playa","Los atardeceres son espectaculares sobre el Pacífico"],"warnings":["El mar puede estar bravo, no te bañes donde pescando los locales"],"faqs":[{"pregunta":"¿Se puede nadar en las playas?","respuesta":"El agua está fría todo el año y puede haber corrientes fuertes. Mejor para avistamiento que para nadar."},{"pregunta":"¿Hay tours organizados?","respuesta":"No hay tours regulares. Es mejor ir por tu cuenta en auto o taxi."}]};
---
<BaseLayout title="Playas Negras de Arena Fina | Alrededores puerto varas" description="Playas únicas con arena volcánica negra y bosque costero">
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #6D28D9 0%, #DB2777 100%);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <a href="/alrededores" class="text-white/70 text-sm hover:text-white no-underline mb-4 inline-block">← Volver a Alrededores</a>
      <h1 class="text-3xl lg:text-4xl font-black text-white mb-2">Playas Negras de Arena Fina</h1>
      <p class="text-white/80 text-lg">Playas únicas con arena volcánica negra y bosque costero</p>
    </div>
  </section>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Playas de Arena Negra</h2><div class="text-gray-600 leading-relaxed prose max-w-none">Caleta La Arena es conocida por sus playas de arena negra成因 por la erosión volcánica de los cerros circundantes. A diferencia de las playas típicas, la arena volcánica tiene una textura única que contrasta dramáticamente con el verde del bosque y el azul del Pacífico. Es uno de los fenómenos naturales más拍照-impresionantes de la zona.</div></div>
          <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Pesca Artesanal y Pueblo Costero</h2><div class="text-gray-600 leading-relaxed prose max-w-none">La caleta es un pueblo pesquero activo donde puedes observar el desembarco de la pesca del día. Los pescadores salen en la madrugada y regresan con corvina, robalo y reineta. Puedes comprar pescado fresco directo del bote a precios increibles. El pueblo tiene cocinerías simples donde sirven empanadas de jaiba y mariscos.</div></div>
          <div class="mb-8"><h2 class="text-2xl font-bold text-gray-900 mb-3">Biodiversidad Marina</h2><div class="text-gray-600 leading-relaxed prose max-w-none">Las aguas de Caleta La Arena son ricas en vida marina. Es común ver delfines cerca de la costa y, en temporada, ballenas grises migrando por el Pacífico. Los avistamientos de aves marinas incluyen albatros, pelícanos y gaviotas australes. El bosque costero adjacent protege poblaciones de nutrias marinas.</div></div>
        <h2 class="text-2xl font-bold text-gray-900 mb-4">Preguntas Frecuentes</h2><details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
          <details class="border-b border-gray-100 pb-4"><summary class="font-semibold text-gray-900 cursor-pointer py-2"></summary><p class="text-gray-600 text-sm mt-2 pl-4"></p></details>
      </div>
      <div class="space-y-4">
        <div class="bg-gray-50 rounded-xl p-4">
          <h4 class="font-semibold text-sm text-gray-900 mb-3">📋 Info Práctica</h4>
          <p class="text-sm text-gray-600 mb-1"><span class="font-medium">Distancia:</span> 20 km (25 minutos)</p>
          <p class="text-sm text-gray-600 mb-1"><span class="font-medium">Dificultad:</span> Fácil</p>
          <p class="text-sm text-gray-600 mb-1"><span class="font-medium">Duración:</span> 3-4 horas</p>
          <p class="text-sm text-gray-600 mb-1"><span class="font-medium">Mejor época:</span> Todo el año (ballenas mayo-octubre)</p>
          <p class="text-sm text-gray-600 mb-1"><span class="font-medium">Entrada:</span> Gratis</p>
        </div>
        <div class="bg-gray-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-gray-900 mb-3">⭐ Highlights</h4><ul class="space-y-1"><li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Playas de arena negra volcánica</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Pesca fresca directo del bote</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Avistamiento de ballenas grises</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Cocinerías de mariscos auténticas</li>
          <li class="flex items-start gap-2 text-gray-600"><span class="text-purple-500 mt-0.5">▸</span> Bosque costero prístino</li></ul></div>
        <div class="bg-purple-50 rounded-xl p-4"><h4 class="font-semibold text-sm text-purple-900 mb-3">💡 Tips</h4><ul class="space-y-2"><li class="text-gray-600 text-sm">💡 Compra pescado fresco en la mañana</li>
          <li class="text-gray-600 text-sm">💡 LlevaBlock para picnic en la playa</li>
          <li class="text-gray-600 text-sm">💡 Los atardeceres son espectaculares sobre el Pacífico</li></ul></div>
        <div class="bg-amber-50 border border-amber-100 rounded-xl p-4"><h4 class="font-semibold text-sm text-amber-900 mb-3">⚠️ Precauciones</h4><ul class="space-y-1"><li class="text-amber-700 text-sm">El mar puede estar bravo, no te bañes donde pescando los locales</li></ul></div>
        
        
        <a href="https://tucorretaje.cl" target="_blank" class="block text-center text-white font-bold py-3 rounded-xl no-underline hover:opacity-90 transition-opacity" style="background: #6D28D9;">🏠 Ver propiedades en puerto varas</a>
      </div>
    </div>
  </section>
</BaseLayout>